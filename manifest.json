{
    "manifest_version": 3,
    "name": "Instagram Image Downloader",
    "version": "1.0",
    "description": "Download single images from Instagram in high quality with one click.",
    "permissions": [
        "downloads",
        "activeTab"
    ],
    "host_permissions": [
        "*://*.instagram.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.instagram.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}